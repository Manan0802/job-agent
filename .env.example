# Free-first LLM: direct Gemini API (Google AI Studio, OpenAI-compatible endpoint)
# Get a free key at https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.5-flash
# Fallback provider: direct Groq API (used automatically if Gemini errors/rate-limits)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
# Paths
DB_PATH=./data/db/career_agent.db
PROFILE_PATH=./data/profile/profile.json
